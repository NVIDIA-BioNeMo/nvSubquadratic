Bootstrap: docker
From: nvcr.io/nvidia/pytorch:25.06-py3

%labels
    Maintainer nvSubquadratic Dev

%environment
    export PYTHONPATH=/workspaces/nvSubquadratic-private:${PYTHONPATH}

%files
    . /workspaces/nvSubquadratic-private

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && \
        apt-get install -y --no-install-recommends build-essential git && \
        rm -rf /var/lib/apt/lists/*
    cd /workspaces/nvSubquadratic-private
    pip install --no-cache-dir -r requirements-dev.txt
    pip install --no-cache-dir -e .
    if [ -n "${GITLAB_TOKEN}" ]; then
        pip install subquadratic-ops==v0.0.1+cuda12.9 \
            --index-url https://__token__:${GITLAB_TOKEN}@gitlab-master.nvidia.com/api/v4/projects/180496/packages/pypi/simple
    else
        echo "Skipping subquadratic-ops installation; set GITLAB_TOKEN to enable."
    fi

%runscript
    exec jupyter lab --ip=0.0.0.0 --port=8888 --no-browser --allow-root "$@"
