Bootstrap: docker
From: nvcr.io/nvidia/pytorch:25.06-py3

%labels
    Maintainer nvSubquadratic Dev

%environment
    export PYTHONPATH=/workspaces/nvSubquadratic:${PYTHONPATH}

%files
    . /workspaces/nvSubquadratic

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && \
        apt-get install -y --no-install-recommends build-essential git && \
        rm -rf /var/lib/apt/lists/*
    cd /workspaces/nvSubquadratic

    # Set up git safe directory
    git config --global --add safe.directory /workspaces/nvSubquadratic

    # Install dependencies
    pip install --no-cache-dir -r requirements-dev.txt
    pip install --no-cache-dir --no-build-isolation -e .

    # Auto-install git hooks on shell entry if missing
    cat >/etc/profile.d/nvsub_precommit.sh <<'EOF'
#!/bin/bash
# Prefer container Python over any host Conda that might be in PATH
export PATH=/usr/local/bin:/usr/bin:$PATH
hash -r

# Ensure CUDA libs are on the path for Triton/TE driver lookups
CUDA_COMPAT=/usr/local/cuda/compat/lib
SINGULARITY_NV_LIB=/.singularity.d/libs
if [ -d "$SINGULARITY_NV_LIB" ]; then
    export LD_LIBRARY_PATH="$SINGULARITY_NV_LIB:${LD_LIBRARY_PATH}"
    if [ -f "$SINGULARITY_NV_LIB/libcuda.so.1" ]; then
        export TRITON_LIBCUDA_PATH="$SINGULARITY_NV_LIB/libcuda.so.1"
    fi
elif [ -d "$CUDA_COMPAT" ]; then
    export LD_LIBRARY_PATH="$CUDA_COMPAT:${LD_LIBRARY_PATH}"
    if [ -f "$CUDA_COMPAT/libcuda.so.1" ]; then
        export TRITON_LIBCUDA_PATH="$CUDA_COMPAT/libcuda.so.1"
    fi
fi

REPO=/workspaces/nvSubquadratic
HOOK="$REPO/.git/hooks/pre-commit"
if [ -d "$REPO/.git" ] && [ ! -f "$HOOK" ]; then
    if command -v pre-commit >/dev/null 2>&1; then
        echo "[nvSubquadratic] Installing pre-commit hooks..."
        (cd "$REPO" && pre-commit install && pre-commit install --hook-type pre-push) || \
            echo "[nvSubquadratic] pre-commit install failed (hooks not installed)."
    else
        echo "[nvSubquadratic] pre-commit not found; skipping hook install."
    fi
fi
unset REPO HOOK CUDA_COMPAT SINGULARITY_NV_LIB
EOF
    chmod +x /etc/profile.d/nvsub_precommit.sh
    # Source the hook installer for interactive shells
    cat >>/etc/bash.bashrc <<'EOF'
# Auto-install nvSubquadratic pre-commit hooks when entering the container
if [ -f /etc/profile.d/nvsub_precommit.sh ]; then
    source /etc/profile.d/nvsub_precommit.sh
fi
EOF

%runscript
    exec jupyter lab --ip=0.0.0.0 --port=8888 --no-browser --allow-root "$@"
